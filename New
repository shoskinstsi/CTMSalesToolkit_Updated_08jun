<style>
  :root{
    --ctm-navy:#003b49;
    --ctm-teal:#007c94;
    --ctm-green:#76bc43;
    --ink:#172033;
    --muted:#667085;
    --bg:#f5f7fa;
    --card:#ffffff;
    --line:#e5e9ef;
  }
  *{box-sizing:border-box}
  body{margin:0;font-family:"Segoe UI",Arial,sans-serif;color:var(--ink);background:var(--bg)}
  .shared-banner{background:#000;color:#fff;padding:8px 18px 14px;position:relative;font-size:15px}
  .shared-banner strong{display:block;font-size:17px;margin-bottom:2px}
  .shared-banner a{color:#fff;text-decoration:underline}
  .edit-pill{position:absolute;right:18px;top:8px;background:#fff;color:#111!important;border-radius:22px;padding:10px 18px;font-weight:700;text-decoration:none!important}

  .site-header{
    background:#fff;border-bottom:1px solid var(--line);padding:20px 7vw;
    display:grid;grid-template-columns:300px 1fr;gap:24px;align-items:start;
    position:sticky;top:0;z-index:5
  }
  .brand{display:flex;gap:16px;align-items:center}
  .ctm-box{width:52px;height:52px;border-radius:14px;background:var(--ctm-navy);color:#fff;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:800;letter-spacing:-1px}
  .site-name{font-size:21px;font-weight:700;margin-bottom:4px}
  .site-sub{color:var(--muted);line-height:1.35}
  .pills{display:flex;gap:10px;flex-wrap:wrap}
  .pill{
    display:inline-flex;align-items:center;gap:9px;background:#f1f4f7;color:#29364a;
    padding:12px 18px;border-radius:999px;text-decoration:none;font-size:17px;
    border:1px solid transparent;cursor:pointer
  }
  .pill:hover{border-color:#cdd5df;background:#e9eef3}
  .pill.active{background:var(--ctm-teal);color:#fff}

  main{max-width:1600px;margin:0 auto;padding:36px 7vw 70px}
  .hero{
    background:linear-gradient(115deg,#003b49 0%,#004b5b 55%,#007c94 100%);
    color:#fff;border-radius:24px;padding:44px 42px;margin-bottom:30px;min-height:300px;
    box-shadow:0 8px 24px rgba(15,23,42,.12);position:relative;overflow:hidden
  }
  .hero:after{
    content:"";position:absolute;right:-100px;top:-120px;width:540px;height:540px;border-radius:50%;
    border:1px solid rgba(255,255,255,.25);
    box-shadow:0 0 0 42px rgba(255,255,255,.02),0 0 0 84px rgba(255,255,255,.018),0 0 0 126px rgba(255,255,255,.012)
  }
  .eyebrow{letter-spacing:.55em;font-size:13px;opacity:.9;text-transform:uppercase;margin-bottom:22px}
  h1{font-size:38px;margin:0 0 20px}
  .hero p{max-width:980px;font-size:18px;line-height:1.65;margin:0 0 28px}
  .owner{display:inline-block;background:rgba(255,255,255,.13);color:#fff;border-radius:999px;padding:12px 18px;font-size:14px}

  .step-grid,.tile-grid,.quick-row,.three-grid,.bid-section-grid{display:grid;gap:18px}
  .step-grid{grid-template-columns:repeat(5,1fr);margin:0 0 30px}
  .tile-grid{grid-template-columns:repeat(4,1fr)}
  .quick-row{grid-template-columns:repeat(4,1fr)}
  .three-grid{grid-template-columns:repeat(3,1fr)}
  .bid-section-grid{grid-template-columns:repeat(5,1fr)}

  .step-card,.tile,.quick-link,.region-tile,.content-card,.bid-card{
    background:#fff;border:1px solid var(--line);border-radius:16px;
    box-shadow:0 2px 8px rgba(15,23,42,.06)
  }

  .step-card,.tile,.quick-link,.region-tile,.bid-card{
    text-decoration:none;color:var(--ink);display:block;cursor:pointer
  }
  .step-card{min-height:124px;padding:28px 26px}
  .step-card:hover,.tile:hover,.region-tile:hover,.quick-link:hover,.bid-card:hover{
    transform:translateY(-2px);transition:.15s ease;box-shadow:0 8px 20px rgba(15,23,42,.12)
  }
  .step-card .num{color:var(--ctm-green);font-size:27px;font-weight:600;letter-spacing:.08em;margin-bottom:18px}
  .step-card h3{margin:0;font-size:18px;line-height:1.35}

  .content-card{padding:26px 30px;margin-bottom:28px}
  .content-card h2{margin:0 0 14px;color:#0b1f35;font-size:22px}
  .content-card p,.content-card li{color:#344054;line-height:1.65}
  .content-card ul{margin:0;padding-left:20px}

  .tile-section{margin-top:34px}
  .section-head{display:flex;align-items:end;justify-content:space-between;gap:18px;margin-bottom:16px}
  .section-head h2{margin:0;font-size:27px;color:#0b1f35}
  .section-head p{margin:0;color:var(--muted)}

  .tile{padding:22px;min-height:150px;display:flex;flex-direction:column;justify-content:space-between}
  .tile-top{display:flex;gap:14px;align-items:flex-start}
  .circle{width:42px;height:42px;border-radius:50%;background:#eef8e9;color:#2d7d1f;display:flex;align-items:center;justify-content:center;font-weight:800;flex:0 0 auto}
  .tile h3{margin:0 0 8px;font-size:18px}
  .tile p{margin:0;color:var(--muted);line-height:1.45;font-size:14px}
  .arrow{align-self:flex-end;color:var(--ctm-teal);font-weight:900;font-size:20px;margin-top:14px}

  .region-tile{padding:28px;min-height:170px;position:relative;overflow:hidden}
  .region-tile:before{content:"";position:absolute;right:-48px;bottom:-48px;width:150px;height:150px;border-radius:50%;background:rgba(118,188,67,.12)}
  .region-tile h3{margin:0 0 10px;font-size:24px;color:#0b1f35}
  .region-tile p{margin:0;color:var(--muted);line-height:1.5}

  .bid-card{padding:24px;min-height:190px;border-top:7px solid var(--ctm-teal)}
  .bid-card:nth-child(2){border-top-color:var(--ctm-green)}
  .bid-card h3{margin:12px 0 10px;font-size:20px;color:#0b1f35}
  .bid-card p{margin:0;color:#344054;line-height:1.55;font-size:15px}
  .bid-num{color:var(--ctm-green);font-size:28px;font-weight:700;letter-spacing:.08em}

  .quick-link{padding:16px 18px;font-weight:700}
  .quick-link:hover{background:#eef8e9;border-color:#a9d66d}

  .backtop{display:inline-block;margin-top:16px;color:var(--ctm-teal);font-weight:700;text-decoration:none;cursor:pointer}
  .view{display:none}
  .view.active{display:block}
  footer{color:var(--muted);padding:24px 7vw 40px;text-align:center}



  .dashboard-summary{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-bottom:22px}
  .metric-card{background:#fff;border:1px solid var(--line);border-radius:16px;padding:22px;box-shadow:0 2px 8px rgba(15,23,42,.06)}
  .metric-label{color:var(--muted);font-size:14px;margin-bottom:8px;font-weight:700;text-transform:uppercase;letter-spacing:.08em}
  .metric-value{font-size:34px;font-weight:800;color:#0b1f35;margin-bottom:6px}
  .metric-note{color:#344054;line-height:1.45;font-size:14px}
  .pipeline-board{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin:22px 0}
  .stage-card{background:#fff;border:1px solid var(--line);border-radius:14px;padding:16px;box-shadow:0 2px 8px rgba(15,23,42,.05);border-top:6px solid var(--ctm-teal)}
  .stage-card:nth-child(2){border-top-color:#4aa7b6}.stage-card:nth-child(3){border-top-color:var(--ctm-green)}.stage-card:nth-child(4){border-top-color:#f0b429}.stage-card:nth-child(5){border-top-color:#ec7a32}.stage-card:nth-child(6){border-top-color:#667085}
  .stage-card h3{margin:0 0 8px;font-size:16px;color:#0b1f35}.stage-card p{margin:0;color:var(--muted);font-size:13px;line-height:1.45}
  .dashboard-table{width:100%;border-collapse:collapse;background:#fff;border:1px solid var(--line);border-radius:16px;overflow:hidden;box-shadow:0 2px 8px rgba(15,23,42,.06)}
  .dashboard-table th,.dashboard-table td{text-align:left;padding:14px 16px;border-bottom:1px solid var(--line);font-size:14px;vertical-align:top}
  .dashboard-table th{background:#f1f4f7;color:#29364a;font-size:13px;text-transform:uppercase;letter-spacing:.06em}
  .dashboard-table tr:last-child td{border-bottom:none}
  .stage-pill{display:inline-block;border-radius:999px;padding:6px 10px;font-weight:700;font-size:12px;background:#eef8e9;color:#2d7d1f;white-space:nowrap}
  .risk-pill{display:inline-block;border-radius:999px;padding:6px 10px;font-weight:700;font-size:12px;background:#fff4e5;color:#a15c00;white-space:nowrap}
  .owner-tag{font-weight:700;color:#0b1f35}
  .questionnaire{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:18px}
  .question-card{background:#fff;border:1px solid var(--line);border-radius:16px;padding:22px;box-shadow:0 2px 8px rgba(15,23,42,.06);border-left:7px solid var(--ctm-teal)}
  .question-card:nth-child(2){border-left-color:var(--ctm-green)}
  .question-card:nth-child(3){border-left-color:#f0b429}
  .question-label{color:var(--ctm-green);font-size:13px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px}
  .question-card h3{margin:0 0 10px;font-size:19px;color:#0b1f35}
  .question-card p{margin:0;color:#344054;line-height:1.55;font-size:14px}
  .debrief-field-list{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:14px}
  .debrief-field{background:#f8fafc;border:1px solid var(--line);border-radius:12px;padding:14px 16px;color:#344054}
  .debrief-field b{color:#0b1f35}

  @media(max-width:1300px){.bid-section-grid,.pipeline-board{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:1200px){.step-grid,.tile-grid,.quick-row,.dashboard-summary{grid-template-columns:repeat(2,1fr)}.site-header{grid-template-columns:1fr}}
  @media(max-width:720px){main{padding:24px 18px}.site-header{padding:20px 18px}.step-grid,.tile-grid,.three-grid,.quick-row,.bid-section-grid,.dashboard-summary,.pipeline-board,.questionnaire,.debrief-field-list{grid-template-columns:1fr}.hero{padding:34px 26px}h1{font-size:31px}.edit-pill{position:static;display:inline-block;margin-top:8px}.dashboard-table{display:block;overflow-x:auto;white-space:nowrap}}

  .rating-row{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-top:14px}
  .rating{background:#f8fafc;border:1px solid var(--line);border-radius:12px;padding:12px;text-align:center;font-weight:800;color:#344054}
  .checklist{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:14px}
  .check{background:#f8fafc;border:1px solid var(--line);border-radius:12px;padding:14px 16px;color:#344054}
  .check:before{content:"☐ ";font-weight:900;color:var(--ctm-teal)}
  .field-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:14px}
  .template-field{background:#f8fafc;border:1px solid var(--line);border-radius:12px;padding:14px 16px;color:#344054;min-height:72px}
  .template-field b{display:block;color:#0b1f35;margin-bottom:8px}
  .blank-line{display:block;border-bottom:1px solid #cfd8e3;min-height:24px;margin-top:6px}
  @media(max-width:720px){.rating-row,.checklist,.field-grid{grid-template-columns:1fr}}

</style>
</head>
